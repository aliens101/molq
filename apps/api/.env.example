HOST=0.0.0.0
PORT=8787
MANTLE_RPC_URL=https://rpc.mantle.xyz

# Bybit execution remains read-only unless all credentials are supplied and trading is armed.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_TRADING_ENABLED=false
BYBIT_MAX_NOTIONAL_USD=10000
BYBIT_LEVERAGE=1
BYBIT_SLIPPAGE_PERCENT=0.5
MOLQ_OPERATOR_API_KEY=

# Vault keeper writes are independently armed and must use the on-chain keeper signer.
MOLQ_KEEPER_PRIVATE_KEY=
MOLQ_KEEPER_ENABLED=false
MOLQ_KEEPER_MAX_SLIPPAGE_BPS=10

# The model proposes strategy actions. Deterministic policy remains active without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
MOLQ_AGENT_MAX_RISK_SCORE=65
MOLQ_AGENT_MIN_FUNDING_APY=1
MOLQ_AGENT_REBALANCE_DRIFT_PERCENT=1
MOLQ_AGENT_ENABLED=false
MOLQ_AGENT_INTERVAL_MS=300000
MOLQ_AGENT_PRIVATE_KEY=
MOLQ_AGENT_WRITES_ENABLED=false
