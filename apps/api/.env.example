HOST=0.0.0.0
PORT=8787
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_RPC_FALLBACK_URLS=https://mantle-rpc.publicnode.com,https://mantle.drpc.org,https://1rpc.io/mantle

# Bybit execution remains read-only unless all credentials are supplied and trading is armed.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_TRADING_ENABLED=false
BYBIT_MAX_NOTIONAL_USD=10000
BYBIT_LEVERAGE=1
BYBIT_SLIPPAGE_PERCENT=0.5
MOLQ_OPERATOR_API_KEY=
MOLQ_ALLOWED_ORIGINS=https://molq.site,https://app.molq.site
MOLQ_OPERATOR_RATE_LIMIT_PER_MINUTE=10
MOLQ_MAX_REQUEST_BODY_BYTES=16384

# Vault keeper writes are independently armed and must use the on-chain keeper signer.
MOLQ_KEEPER_PRIVATE_KEY=
MOLQ_KEEPER_ENABLED=false
MOLQ_KEEPER_MAX_SLIPPAGE_BPS=10
MOLQ_PROFIT_HARDENING_ENABLED=false
MOLQ_MAX_HARDEN_PROFIT_USD=1000

# The model proposes strategy actions. Deterministic policy remains active without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
MOLQ_AGENT_MAX_RISK_SCORE=65
MOLQ_AGENT_MIN_FUNDING_APY=1
MOLQ_AGENT_MIN_HEDGE_NOTIONAL_USD=10
MOLQ_AGENT_REBALANCE_DRIFT_PERCENT=1
MOLQ_AGENT_ENABLED=false
MOLQ_AGENT_INTERVAL_MS=300000
MOLQ_AGENT_PRIVATE_KEY=
MOLQ_AGENT_WRITES_ENABLED=false
MOLQ_AGENT_ID=112

# Persisted strategy telemetry and production monitoring.
MOLQ_TELEMETRY_PATH=data/performance.jsonl
MOLQ_TELEMETRY_INTERVAL_MS=60000
MOLQ_TELEMETRY_MAX_POINTS=2016
MOLQ_INDEXER_GRAPHQL_URL=https://indexer.molq.site/graphql
MOLQ_INDEXER_HEALTH_URL=http://127.0.0.1:8071/health
MOLQ_MONITOR_HEALTH_URL=http://127.0.0.1:8070/api/health/deep
MOLQ_MONITOR_INTERVAL_MS=60000
MOLQ_ALERT_WEBHOOK_URL=
