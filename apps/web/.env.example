# MolQ — Mantle config (copy to .env.local and fill)
# Frontend talks to Mantle (EVM). The Warden/Cosmos VITE_* vars in src/env.ts are
# retained from the copied web foundation but are not required for the MolQ starter.

VITE_MANTLE_RPC_URL=https://rpc.mantle.xyz
VITE_MANTLE_CHAIN_ID=5000
VITE_MANTLE_EXPLORER=https://mantlescan.xyz

# Deployed MolQ contracts (fill after `forge script` deploy)
VITE_MOLQ_ASSET=0x5d3a1Ff2b6BAb83b63cd9AD0787074081a52ef34
VITE_MOLQ_VAULT=0x71711F35c200fDabE75F2e82F0146c35f32eBAA5
VITE_MOLQ_DECISION_LOGGER=0xb6e5499C97138Ee6E25d1E904b6714BD0E60f139

# Verified ecosystem contracts (see packages/shared/src/addresses.ts)
VITE_LB_PAIR=0xfc9D88653E2988B0e6525f1F521c974a25c88566
VITE_ERC8004_REPUTATION=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
VITE_PYTH=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
